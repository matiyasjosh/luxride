---

<section id="hero" class="hero">
  <!-- The background image with a subtle zoom animation -->
  <div class="hero-bg" style="background-image: url('zema-1.jpg');"></div>
  
  <!-- Elegant gradient overlay to make text pop while showcasing the car and chauffeur -->
  <div class="hero-overlay"></div>

  <div class="container hero-content">
    <div class="hero-left">
      <div class="brand-tag fade-up">
        <span class="line"></span>
        <p>Zema Executive Limo</p>
      </div>
      
      <h1 class="hero-title fade-up">
        Arrive in<br />
        <em>Pure Luxury</em>
      </h1>
      
      <p class="hero-subtitle fade-up">
      Unrivaled elegance. Flawless precision. Every journey with ZEMA 
      Executive Limo is an experience crafted to be remembered.
      </p>

      
      <div class="hero-actions fade-up">
        <a href="#booking" class="btn-primary glow-effect">
          <span>Book a Ride</span>
        </a>
        <a href="#fleet" class="btn-secondary glass-effect">
          <span>View Fleet</span>
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>

    <!-- Stats moved to an elegant glassmorphism floating bar at the bottom -->
    <div class="hero-stats-wrapper fade-up">
      <div class="hero-stats glass-panel">
        <div class="stat">
          <span class="stat-number">1</span>
          <span class="stat-label">Year of<br>Excellence</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <span class="stat-number">50+</span>
          <span class="stat-label">Happy<br>Clients</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <span class="stat-number">24/7</span>
          <span class="stat-label">Premium<br>Availability</span>
        </div>
      </div>
    </div>
  </div>

  <div class="scroll-indicator">
    <div class="scroll-line"></div>
    <span>Scroll</span>
  </div>
</section>

<!-- Lightweight script to trigger the fade-up animations on load -->
<script>
  document.addEventListener("DOMContentLoaded", () => {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.fade-up').forEach((el) => observer.observe(el));
  });
</script>

<style>
  /* --- BASE HERO STYLES --- */
  .hero {
    position: relative;
    width: 100%;
    height: 100vh;
    min-height: 800px;
    display: flex;
    align-items: center;
    overflow: hidden;
    background-color: #050505;
    color: #ffffff;
    font-family: 'Inter', system-ui, sans-serif; /* Replace with your primary font */
  }

  .container {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
    position: relative;
    z-index: 2;
  }

  /* --- BACKGROUND & OVERLAY --- */
  .hero-bg {
    position: absolute;
    inset: -5%; /* Slightly larger for the zoom effect */
    width: 110%;
    height: 110%;
    background-size: cover;
    background-position: center 30%; /* Focuses slightly above center to keep chauffeur's face visible */
    opacity: 45%;
    background-repeat: no-repeat;
    z-index: 0;
    animation: gentleZoom 25s linear infinite alternate;
  }

  @keyframes gentleZoom {
    0% { transform: scale(1); }
    100% { transform: scale(1.08); }
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    /* Darker on the left for text, transitioning to clear on the right for the car/chauffeur */
    background: linear-gradient(
      90deg,
      rgba(0, 0, 0, 0.9) 0%,
      rgba(0, 0, 0, 0.7) 40%,
      rgba(0, 0, 0, 0.2) 80%,
      rgba(0, 0, 0, 0.1) 100%
    ),
    /* Bottom gradient to blend stats smoothly */
    linear-gradient(
      0deg,
      rgba(0, 0, 0, 0.8) 0%,
      transparent 30%
    );
  }

  /* --- CONTENT LAYOUT --- */
  .hero-content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    height: 100%;
    padding-top: 5vh;
  }

  .hero-left {
    max-width: 600px;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  /* --- TYPOGRAPHY --- */
  .brand-tag {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .brand-tag .line {
    width: 40px;
    height: 1px;
    background-color: #d4af37; /* Gold */
  }

  .brand-tag p {
    font-size: 0.85rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #d4af37;
    font-weight: 500;
    margin: 0;
  }

  .hero-title {
    font-size: clamp(3.5rem, 7vw, 5.5rem);
    font-weight: 300;
    color: #ffffff;
    line-height: 1.1;
    margin: 0;
    text-shadow: 0 10px 30px rgba(0,0,0,0.5);
  }

  .hero-title em {
    font-style: italic;
    font-family: 'Playfair Display', serif; /* Replace with your var(--font-serif) */
    color: #d4af37;
  }

  .hero-subtitle {
    font-size: 1.125rem;
    color: #e0e0e0;
    line-height: 1.6;
    font-weight: 300;
    margin: 0;
    max-width: 80%;
  }

  /* --- BUTTONS --- */
  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 1rem;
  }

  .btn-primary, .btn-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 1rem 2.2rem;
    font-size: 0.9rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .btn-primary {
    background: #d4af37;
    color: #000000;
    font-weight: 600;
  }

  .btn-primary:hover {
    background: #e5c158;
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(212, 175, 55, 0.2);
  }

  .btn-secondary.glass-effect {
    background: rgba(255, 255, 255, 0.05);
    color: #ffffff;
    border: 1px solid rgba(255, 255, 255, 0.2);
    backdrop-filter: blur(10px);
  }

  .btn-secondary:hover {
    background: rgba(255, 255, 255, 0.15);
    border-color: #d4af37;
    transform: translateY(-2px);
  }

  /* --- STATS SECTION (Glassmorphism) --- */
  .hero-stats-wrapper {
    position: absolute;
    bottom: 80px;
    left: 2rem;
  }

  .glass-panel {
    display: flex;
    align-items: center;
    gap: 2.5rem;
    background: rgba(15, 15, 15, 0.4);
    border: 1px solid rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    padding: 1.5rem 3rem;
    border-radius: 4px;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
  }

  .stat {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .stat-number {
    font-family: 'Playfair Display', serif; /* Replace with var(--font-serif) */
    font-size: 2.5rem;
    font-weight: 400;
    color: #d4af37;
    line-height: 1;
  }

  .stat-label {
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #a0a0a0;
    font-weight: 500;
    line-height: 1.4;
  }

  .stat-divider {
    width: 1px;
    height: 40px;
    background: rgba(255, 255, 255, 0.1);
  }

  /* --- SCROLL INDICATOR --- */
  .scroll-indicator {
    position: absolute;
    bottom: 30px;
    right: 3rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    z-index: 2;
  }

  .scroll-line {
    width: 1px;
    height: 60px;
    background: linear-gradient(to bottom, #d4af37, transparent);
    animation: scrollPulse 2s cubic-bezier(0.4, 0, 0.2, 1) infinite;
  }

  .scroll-indicator span {
    font-size: 0.65rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: #888;
    writing-mode: vertical-rl;
    transform: rotate(180deg);
  }

  @keyframes scrollPulse {
    0% { transform-origin: top; transform: scaleY(0); opacity: 0; }
    50% { transform-origin: top; transform: scaleY(1); opacity: 1; }
    51% { transform-origin: bottom; transform: scaleY(1); opacity: 1; }
    100% { transform-origin: bottom; transform: scaleY(0); opacity: 0; }
  }

  /* --- ANIMATIONS --- */
  .fade-up {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 1s cubic-bezier(0.2, 0.8, 0.2, 1), transform 1s cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .hero-left .fade-up:nth-child(1) { transition-delay: 0.2s; }
  .hero-left .fade-up:nth-child(2) { transition-delay: 0.4s; }
  .hero-left .fade-up:nth-child(3) { transition-delay: 0.6s; }
  .hero-left .fade-up:nth-child(4) { transition-delay: 0.8s; }
  .hero-stats-wrapper.fade-up { transition-delay: 1.0s; }

  .fade-up.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* --- RESPONSIVE DESIGN --- */
  @media (max-width: 992px) {
    .hero-overlay {
      background: linear-gradient(
        90deg,
        rgba(0, 0, 0, 0.95) 0%,
        rgba(0, 0, 0, 0.8) 50%,
        rgba(0, 0, 0, 0.4) 100%
      );
    }
  }

  @media (max-width: 768px) {
    .hero-title {
      font-size: clamp(2.5rem, 8vw, 3.5rem);
    }
    
    .hero-subtitle {
      max-width: 100%;
    }

    .hero-stats-wrapper {
      position: relative;
      bottom: auto;
      left: auto;
      margin-top: 3rem;
    }

    .glass-panel {
      flex-direction: column;
      align-items: flex-start;
      gap: 1.5rem;
      padding: 1.5rem;
    }

    .stat-divider {
      width: 100%;
      height: 1px;
    }

    .scroll-indicator {
      display: none; /* Hide on mobile to save space */
    }
  }
</style>
