
---
---

<section id="contact" class="contact-section">
  <div class="container">
    <div class="contact-grid">
      <div class="contact-info fade-up">
        <p class="section-label">Find Us</p>
        <div class="gold-line" style="margin: 16px 0;"></div>
        <h2 class="contact-title">Always <em>Within Reach</em></h2>
        <p class="contact-desc">
          Whether you're planning ahead or need a last-minute arrangement, 
          our team is here for you at any hour.
        </p>

        <div class="info-list">
          <div class="info-item">
            <div class="info-icon">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                <path d="M9 2C6.24 2 4 4.24 4 7c0 3.75 5 9 5 9s5-5.25 5-9c0-2.76-2.24-5-5-5z" stroke="currentColor" stroke-width="1.2"/>
                <circle cx="9" cy="7" r="1.5" stroke="currentColor" stroke-width="1.2"/>
              </svg>
            </div>
            <div>
              <strong>Headquarters</strong>
              <span>Austin Texas</span>
            </div>
          </div>
          <div class="info-item">
            <div class="info-icon">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                <path d="M2 4.5h14v9a1 1 0 01-1 1H3a1 1 0 01-1-1v-9z" stroke="currentColor" stroke-width="1.2"/>
                <path d="M2 4.5l7 5 7-5" stroke="currentColor" stroke-width="1.2"/>
              </svg>
            </div>
            <div>
              <strong>Email</strong>
              <span>info@zemalimo.com<br/>reserve@zemaexecutivelimo.com</span>
            </div>
          </div>
          <div class="info-item">
            <div class="info-icon">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                <path d="M2 4h4l1 4-2.5 1.5a9 9 0 004 4L10 11l4 1v4a1 1 0 01-1 1A15 15 0 011 3a1 1 0 011-1z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"/>
              </svg>
            </div>
            <div>
              <strong>Phone</strong>
              <span>+1 (800) 555-9999<br/>Available 24/7</span>
            </div>
          </div>
        </div>

        <div class="social-links">
          <a href="#" class="social-link" aria-label="Instagram">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
              <rect x="2" y="2" width="14" height="14" rx="4" stroke="currentColor" stroke-width="1.2"/>
              <circle cx="9" cy="9" r="3" stroke="currentColor" stroke-width="1.2"/>
              <circle cx="13" cy="5" r="0.8" fill="currentColor"/>
            </svg>
          </a>
          <a href="#" class="social-link" aria-label="Facebook">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
              <path d="M10 2h-2a3 3 0 00-3 3v2H3v3h2v6h3v-6h2l1-3h-3V5a1 1 0 011-1h2V2z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"/>
            </svg>
          </a>
          <a href="#" class="social-link" aria-label="Twitter/X">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
              <path d="M2 2l5.5 6L2 16h2l4.3-5 3.7 5H16l-5.8-7.8L15.5 2h-2l-3.8 4.3L6 2H2z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"/>
            </svg>
          </a>
          <a href="#" class="social-link" aria-label="LinkedIn">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
              <rect x="2" y="2" width="14" height="14" rx="2" stroke="currentColor" stroke-width="1.2"/>
              <path d="M6 8v5M6 6v.01M9 13V9.5a1.5 1.5 0 013 0V13M9 9v4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Map placeholder with styling -->
      <div class="map-wrap fade-up" style="transition-delay: 0.2s;">
        <div class="map-inner">
          <img
            src="austin-texas.jpg"
            alt="City lights"
            class="map-img"
            loading="lazy"
          />
          <div class="map-overlay">
            <div class="map-pin">
              <svg width="32" height="40" viewBox="0 0 32 40" fill="none">
                <path d="M16 2C9.37 2 4 7.37 4 14c0 9.5 12 24 12 24S28 23.5 28 14C28 7.37 22.63 2 16 2z" fill="#c9a84c" stroke="#0a0a0a" stroke-width="1.5"/>
                <circle cx="16" cy="14" r="4" fill="#0a0a0a"/>
              </svg>
              <div class="map-pin-label">ZEMALIMO HQ</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<footer class="footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <a href="#hero" class="nav-logo footer-logo">
        <img src="zema-log.png" alt="zema-logo" width=50 height=50>
        <span>ZEMALIMO</span>
      </a>
      <p class="footer-tagline">The standard of luxury transportation.</p>
    </div>

    <div class="footer-links">
      <div class="footer-col">
        <h4>Services</h4>
        <ul>
          <li><a href="#services">Airport Transfers</a></li>
          <li><a href="#services">Corporate Travel</a></li>
          <li><a href="#services">City Tours</a></li>
          <li><a href="#services">Weddings & Events</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h4>Fleet</h4>
        <ul>
          <li><a href="#fleet">Executive Stretch</a></li>
          <li><a href="#fleet">Mercedes S-Class</a></li>
          <li><a href="#fleet">Cadillac Escalade</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h4>Company</h4>
        <ul>
          <li><a href="#experience">About Us</a></li>
          <li><a href="#contact">Contact</a></li>
          <li><a href="#booking">Reservations</a></li>
          <li><a href="#">Privacy Policy</a></li>
        </ul>
      </div>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="container footer-bottom-inner">
      <p>&copy; {new Date().getFullYear()} ZEMALIMOEXECUTIVE. All rights reserved.</p>
      <div class="footer-bottom-line"></div>
      <p class="footer-craft">Crafted for the discerning traveler.</p>
    </div>
  </div>
</footer>

<style>
  .contact-section {
    padding: var(--space-16) 0;
    background: var(--color-dark);
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 80px;
    align-items: center;
  }

  .contact-title {
    font-size: clamp(2rem, 3.5vw, 3rem);
    font-weight: 300;
    color: var(--color-white);
    margin-bottom: var(--space-3);
  }

  .contact-title em {
    font-style: italic;
    color: var(--color-gold);
  }

  .contact-desc {
    color: var(--color-gray-2);
    font-size: 0.9rem;
    line-height: 1.9;
    margin-bottom: var(--space-4);
  }

  .contact-info {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .info-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .info-item {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
  }

  .info-icon {
    width: 40px;
    height: 40px;
    border: 1px solid rgba(201, 168, 76, 0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-gold);
    flex-shrink: 0;
  }

  .info-item strong {
    display: block;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-gray-2);
    margin-bottom: 6px;
  }

  .info-item span {
    font-size: 0.85rem;
    color: var(--color-white-off);
    line-height: 1.7;
  }

  .social-links {
    display: flex;
    gap: var(--space-2);
    margin-top: var(--space-1);
  }

  .social-link {
    width: 40px;
    height: 40px;
    border: 1px solid var(--color-dark-3);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-gray-2);
    transition: all 0.3s ease;
  }

  .social-link:hover {
    border-color: var(--color-gold);
    color: var(--color-gold);
  }

  /* Map */
  .map-wrap {
    border: 1px solid var(--color-dark-3);
  }

  .map-inner {
    position: relative;
    aspect-ratio: 4/3;
    overflow: hidden;
  }

  .map-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.4) saturate(0.6);
  }

  .map-overlay {
    position: absolute;
    inset: 0;
    background: rgba(10, 10, 10, 0.3);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .map-pin {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    animation: pinBounce 2s ease-in-out infinite;
  }

  .map-pin-label {
    background: rgba(10, 10, 10, 0.9);
    border: 1px solid var(--color-gold);
    color: var(--color-gold);
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    font-weight: 500;
    padding: 6px 16px;
    white-space: nowrap;
  }

  @keyframes pinBounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }

  /* Footer */
  .footer {
    background: var(--color-black);
    border-top: 1px solid var(--color-dark-3);
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 1.2fr 2fr;
    gap: 80px;
    padding: var(--space-10) var(--space-4);
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .footer-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    color: var(--color-white);
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.35em;
  }

  .footer-logo svg {
    color: var(--color-gold);
  }

  .footer-tagline {
    font-size: 0.82rem;
    color: var(--color-gray-3);
    font-style: italic;
    font-family: var(--font-serif);
  }

  .footer-links {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
  }

  .footer-col h4 {
    font-family: var(--font-sans);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-gray-2);
    margin-bottom: var(--space-3);
  }

  .footer-col ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .footer-col a {
    font-size: 0.82rem;
    color: var(--color-gray-3);
    transition: color 0.2s ease;
  }

  .footer-col a:hover {
    color: var(--color-gold);
  }

  .footer-bottom {
    border-top: 1px solid var(--color-dark-3);
    padding: var(--space-3) 0;
  }

  .footer-bottom-inner {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  .footer-bottom p {
    font-size: 0.72rem;
    color: var(--color-gray-4);
    letter-spacing: 0.05em;
  }

  .footer-bottom-line {
    flex: 1;
    height: 1px;
    background: var(--color-dark-3);
  }

  .footer-craft {
    font-family: var(--font-serif) !important;
    font-style: italic;
    color: var(--color-gray-4) !important;
  }

  @media (max-width: 900px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 50px;
    }

    .footer-inner {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .footer-links {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 580px) {
    .footer-links {
      grid-template-columns: 1fr 1fr;
    }

    .footer-bottom-inner {
      flex-direction: column;
      text-align: center;
      gap: var(--space-2);
    }

    .footer-bottom-line {
      display: none;
    }
  }
</style>
